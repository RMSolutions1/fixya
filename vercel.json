{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run vercel-build",
  "devCommand": "npm run web:dev",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "regions": ["gru1"],
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
