# =============================================================================
# FixYa — Variables de entorno
# Copiar este archivo a .env y completar los valores antes de desplegar.
# NUNCA commitear el .env con valores reales al repositorio.
# =============================================================================

# ── Base de datos (Neon.tech / Supabase / PostgreSQL) ─────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CAMBIAR_POR_UN_SECRET_DE_64_CHARS_MINIMO"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/settings/account/credentials
# Producción: usar el Access Token de producción (APP_USR-...)
# Pruebas: usar el Access Token de prueba (TEST-...)
MP_ACCESS_TOKEN="APP_USR-XXXXXXXXXXXXXXXX"

# Secret del webhook: Panel MP → Tu negocio → Notificaciones → Webhooks
# Copiar el "Secret" que genera MP al crear el endpoint
MP_WEBHOOK_SECRET="CAMBIAR_POR_SECRET_DEL_WEBHOOK_MP"

# Modo sandbox (solo para desarrollo local — NUNCA true en producción)
MP_SANDBOX="false"

# ── URLs públicas ─────────────────────────────────────────────────────────────
# URL pública del frontend (sin barra final)
APP_PUBLIC_URL="https://fixya.emprenor.com"

# URL pública de la API (donde MP enviará webhooks)
# En Vercel monorepo, generalmente es la misma URL del frontend
API_PUBLIC_URL="https://fixya.emprenor.com"

# ── Email transaccional (Resend) ──────────────────────────────────────────────
# Obtener en: https://resend.com → API Keys
# Dominio "fixya.emprenor.com" debe estar verificado en Resend
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS="https://fixya.emprenor.com"

# ── Comportamiento de la app ──────────────────────────────────────────────────
NODE_ENV="production"
PORT="4000"
API_PREFIX="v1"

# Swagger UI (SIEMPRE false en producción)
ENABLE_SWAGGER="false"

# Sandbox de pagos (SIEMPRE false en producción)
ENABLE_SANDBOX_PAYMENTS="false"

# ── Sentry (opcional — monitoreo de errores) ──────────────────────────────────
# SENTRY_DSN="https://xxxx@sentry.io/yyyy"
# NEXT_PUBLIC_SENTRY_DSN="https://xxxx@sentry.io/yyyy"

# ── Google Analytics (opcional) ───────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# =============================================================================
# CHECKLIST ANTES DE DESPLEGAR A PRODUCCIÓN
# =============================================================================
# [ ] JWT_SECRET tiene al menos 64 caracteres y no contiene "dev" o "change"
# [ ] MP_ACCESS_TOKEN + MP_WEBHOOK_SECRET — cuando tengas credenciales: npm run mp:enable
# [ ] RESEND_API_KEY — emails transaccionales (opcional hasta go-live)
# [ ] APP_PUBLIC_URL y API_PUBLIC_URL apuntan al dominio real (sin /api/v1 en API_PUBLIC_URL)
# [ ] ENABLE_SWAGGER="false"
# [ ] ENABLE_SANDBOX_PAYMENTS="false"
# [ ] MP_SANDBOX="false"
# [ ] NODE_ENV="production"
# [ ] En Vercel: configurar todas estas variables en Settings → Environment Variables
# =============================================================================
