# FixYa — Variables de entorno

# ─── Base de datos ───────────────────────────────────────────────
# Local (Docker):
# DATABASE_URL="postgresql://fixya:fixya@localhost:5433/fixya?schema=public"
# Supabase (Grupo Emprenor — grupo.emprenor.com):
DATABASE_URL="postgresql://postgres.qsowfnlmpwjfrqjemsnt:[SUPABASE_DB_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[SUPABASE_DB_PASSWORD]@db.qsowfnlmpwjfrqjemsnt.supabase.co:5432/postgres"

# Supabase API (opcional — apps/web/.env.local)
SUPABASE_URL="https://qsowfnlmpwjfrqjemsnt.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY=           # Solo en .env.local, no commitear

# ─── Seguridad (obligatorio en producción) ───────────────────────
JWT_SECRET=                          # Mínimo 32 caracteres, valor único y seguro
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── API ─────────────────────────────────────────────────────────
PORT=4000
API_PREFIX=v1
NODE_ENV=development                 # production en deploy real
CORS_ORIGINS=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
ENABLE_SWAGGER=true                  # false en producción
ENABLE_SANDBOX_PAYMENTS=false        # true solo en desarrollo local

# ─── Mercado Pago (obligatorio en producción) ─────────────────────
MP_ACCESS_TOKEN=                     # Token de producción o TEST según entorno
MP_SANDBOX=true                      # false en producción

# ─── Seed (solo primera instalación / desarrollo) ────────────────
# ADMIN_EMAIL=admin@tuempresa.com.ar
# ADMIN_PASSWORD=                    # Contraseña segura del administrador inicial
# ADMIN_FIRST_NAME=Administrador
# ADMIN_LAST_NAME=FixYa
# SEED_DEMO_DATA=false               # true solo para datos de prueba locales
# SEED_DEMO_PASSWORD=FixYa2026!      # Contraseña usuarios demo y @fixya.test

# ─── Frontend (apps/web/.env.local) ──────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# NEXT_PUBLIC_ENABLE_SANDBOX_PAYMENTS=false
