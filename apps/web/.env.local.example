# FixYa Web — Grupo Emprenor / Supabase
NEXT_PUBLIC_SITE_URL=https://fixya.emprenor.com
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_ENABLE_SANDBOX_PAYMENTS=false

# Supabase (compartido con grupo.emprenor.com)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres para Prisma (Dashboard → Settings → Database → Database password)
# Región y prefijo del pooler (Supabase → Connect → copiar host, ej. aws-1-us-east-2)
SUPABASE_REGION=us-east-2
SUPABASE_POOLER_PREFIX=aws-1
SUPABASE_DB_PASSWORD=

# Alternativa: pegar connection strings completos del dashboard
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres
