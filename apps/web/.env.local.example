# FixYa Web — Neon (Vercel Postgres) + dominio producción
NEXT_PUBLIC_SITE_URL=https://fixya.emprenor.com
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ENABLE_SANDBOX_PAYMENTS=false

# Neon — pegar desde Vercel Storage / Neon dashboard
DATABASE_URL=postgres://USER:PASS@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASS@HOST.region.aws.neon.tech/neondb?sslmode=require
POSTGRES_PRISMA_URL=postgres://USER:PASS@HOST-pooler.region.aws.neon.tech/neondb?connect_timeout=15&sslmode=require

# Supabase Auth (opcional)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
