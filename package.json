{
  "name": "fixya",
  "version": "1.0.0",
  "private": true,
  "description": "FixYa — Sistema Operativo para Servicios",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx scripts/seed-demo.ts",
    "db:seed:users": "tsx scripts/seed-test-users.ts",
    "db:import:registry": "tsx scripts/import-registry-professionals.ts",
    "scrape:copaipa": "node scripts/scrape-copaipa-padron.mjs",
    "db:import:copaipa": "tsx scripts/import-copaipa-padron.ts",
    "db:import:copaipa:directory": "tsx scripts/import-copaipa-padron.ts --activate",
    "db:approve:copaipa": "tsx scripts/approve-copaipa-directory.ts",
    "sync:copaipa": "node scripts/scrape-copaipa-padron.mjs && tsx scripts/import-copaipa-padron.ts",
    "db:clean-demo": "tsx scripts/clean-demo-data.ts",
    "api:dev": "npm run dev -w @fixya/api",
    "api:build": "npm run build -w @fixya/api",
    "api:bundle": "npm run api:build && node scripts/copy-api-dist.mjs",
    "api:build:nest": "npx nest build --path apps/api",
    "api:start": "npm run start:prod -w @fixya/api",
    "web:dev": "node scripts/ensure-api-runtime.mjs && npm run dev -w @fixya/web",
    "web:build": "node scripts/ensure-api-runtime.mjs && npm run build -w @fixya/web",
    "vercel-build": "npm run db:generate && npm run build -w @fixya/database && npm run api:bundle && npm run web:build",
    "build": "npm run db:generate && npm run api:bundle && npm run build -w @fixya/web",
    "test": "npm run test -w @fixya/api",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:smoke:auth": "node scripts/smoke-auth.mjs",
    "test:e2e": "node scripts/smoke-test.mjs && node scripts/smoke-auth.mjs",
    "test:dashboard": "node scripts/e2e-dashboard.mjs",
    "test:all": "node scripts/smoke-test.mjs && node scripts/smoke-auth.mjs && node scripts/e2e-dashboard.mjs",
    "test:audit": "node scripts/audit-full.mjs",
    "test:full": "node scripts/smoke-test.mjs && node scripts/smoke-auth.mjs && node scripts/e2e-dashboard.mjs && node scripts/audit-full.mjs",
    "sync:grupo-env": "node scripts/sync-grupo-env.mjs",
    "verify": "npm run test && npm run build"
  },
  "devDependencies": {
    "@vercel/node": "^5.0.0",
    "esbuild": "^0.28.1",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
